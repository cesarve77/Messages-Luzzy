    <string name="prominent_disclosure_title">Notificare de confidențialitate</string>
    <string name="prominent_disclosure_message">Luzzy colectează și transmite numărul tău de telefon și contactele de pe dispozitiv pentru a permite trimiterea și primirea de mesaje SMS între utilizatori. Aceste informații sunt trimise pe serverele noastre exclusiv în acest scop și nu sunt partajate cu terți.</string>
    <string name="prominent_disclosure_accept">Accept</string>
