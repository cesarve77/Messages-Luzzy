    <!-- Permission Rationale Dialogs (Google Play compliance) -->
    <string name="sms_permission_rationale_title">Luzzy needs access</string>
    <string name="sms_permission_rationale_message">To work as your messaging app, Luzzy needs:\n\n• Read and send SMS — to manage your text messages\n• Read contacts — to show names in your conversations\n\nThese permissions are used solely for SMS messaging and are never shared with third parties.</string>
    <string name="default_sms_rationale_title">Default SMS app</string>
    <string name="default_sms_rationale_message">To send and receive SMS messages, Luzzy needs to be your default messaging app.\n\nThis lets Luzzy:\n• Receive incoming SMS\n• Send messages on your behalf\n• Show you notifications for new messages\n\nYou can change this at any time in your device settings.</string>
