<resources>

    <!-- Elimina el fondo gris de CUALQUIER EditText en la app -->
    <style name="TransparentEditText" parent="Widget.AppCompat.EditText">
        <item name="android:background">@android:color/transparent</item>
    </style>

    <style name="AppTheme" parent="AppTheme.Base">
        <item name="android:editTextStyle">@style/TransparentEditText</item>
    </style>

    <style name="roundedImageView" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/normal_margin</item>
    </style>

    <style name="LetterFastscrollerStyleSmall">
        <item name="android:textSize">@dimen/small_text_size</item>
        <item name="android:alpha">0.8</item>
    </style>

    <style name="LetterFastscrollerStyleTiny">
        <item name="android:textSize">@dimen/tiny_text_size</item>
        <item name="android:alpha">0.8</item>
    </style>

    <style name="LetterFastscrollerStyleTooTiny">
        <item name="android:textSize">@dimen/too_tiny_text_size</item>
        <item name="android:alpha">0.8</item>
    </style>

    <style name="AppTheme.FullScreen" parent="AppTheme">
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>
</resources>
