<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/theme_black_background_color">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/user_settings_title" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/nested_scroll_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/activity_margin">

            <!-- ── Banner premium (solo si no es premium) ── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/premium_banner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/big_margin"
                android:visibility="gone"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                tools:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/activity_margin">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/unlock_premium_features"
                        android:textSize="@dimen/big_text_size"
                        android:textStyle="bold"
                        android:layout_marginBottom="@dimen/small_margin" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/premium_features_description"
                        android:textSize="@dimen/normal_text_size"
                        android:alpha="0.7"
                        android:layout_marginBottom="@dimen/medium_margin" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/upgrade_premium_button"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/upgrade_to_premium"
                        app:cornerRadius="8dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Google Account ── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/big_margin"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/activity_margin">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/google_login_title"
                        android:textSize="@dimen/big_text_size"
                        android:textStyle="bold"
                        android:layout_marginBottom="@dimen/medium_margin" />

                    <LinearLayout
                        android:id="@+id/google_logged_in_layout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/google_account_email"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="@dimen/normal_text_size"
                            android:layout_marginBottom="@dimen/medium_margin"
                            android:alpha="0.7"
                            tools:text="usuario@gmail.com" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/google_logout_button"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/logout_google"
                            app:cornerRadius="8dp"
                            style="@style/Widget.Material3.Button.OutlinedButton" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/google_logged_out_layout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/google_login_description"
                            android:textSize="@dimen/normal_text_size"
                            android:layout_marginBottom="@dimen/medium_margin"
                            android:alpha="0.7" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/google_login_button"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/login_with_google"
                            app:icon="@drawable/ic_google"
                            app:iconGravity="textStart"
                            app:iconPadding="12dp"
                            app:cornerRadius="8dp"
                            style="@style/Widget.Material3.Button.ElevatedButton" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ══════════════════════════════════════════════
                 CONFIGURACIÓN GENERAL
            ══════════════════════════════════════════════ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/general_settings"
                android:textSize="@dimen/big_text_size"
                android:textStyle="bold"
                android:layout_marginBottom="@dimen/medium_margin" />

            <!-- Nombre de usuario -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/nombre_usuario_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/nombre_usuario"
                app:helperText="@string/nombre_usuario_helper"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_marginBottom="@dimen/medium_margin">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/nombre_usuario_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPersonName"
                    android:maxLines="1" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Notificaciones silenciosas -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="@dimen/medium_margin"
                android:layout_marginBottom="@dimen/small_margin">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/notificaciones_silenciosas"
                        android:textSize="@dimen/normal_text_size" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/notificaciones_silenciosas_desc"
                        android:textSize="@dimen/smaller_text_size"
                        android:alpha="0.7" />
                </LinearLayout>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/notificaciones_silenciosas_switch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- Modo oscuro -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="@dimen/medium_margin"
                android:layout_marginBottom="@dimen/big_margin">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/modo_oscuro"
                        android:textSize="@dimen/normal_text_size" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/modo_oscuro_desc"
                        android:textSize="@dimen/smaller_text_size"
                        android:alpha="0.7" />
                </LinearLayout>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/modo_oscuro_switch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- ══════════════════════════════════════════════
                 CONFIGURACIÓN PREMIUM (sincronizada con web)
            ══════════════════════════════════════════════ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/premium_settings"
                android:textSize="@dimen/big_text_size"
                android:textStyle="bold"
                android:layout_marginBottom="@dimen/medium_margin" />

            <!-- Auto-Respuesta -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="@dimen/medium_margin"
                android:layout_marginBottom="@dimen/small_margin">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/auto_respuesta_activada"
                        android:textSize="@dimen/normal_text_size" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/auto_respuesta_desc"
                        android:textSize="@dimen/smaller_text_size"
                        android:alpha="0.7" />
                </LinearLayout>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/auto_respuesta_switch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- Usar emojis -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="@dimen/medium_margin"
                android:layout_marginBottom="@dimen/big_margin">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/usar_emojis"
                        android:textSize="@dimen/normal_text_size" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/usar_emojis_desc"
                        android:textSize="@dimen/smaller_text_size"
                        android:alpha="0.7" />
                </LinearLayout>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/usar_emojis_switch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- ── Perfil Profesional ── -->
            <TextView
                android:id="@+id/perfil_profesional_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/perfil_profesional"
                android:textSize="@dimen/big_text_size"
                android:textStyle="bold"
                android:layout_marginBottom="@dimen/medium_margin" />

            <!-- Mis servicios -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/mis_servicios"
                android:textSize="@dimen/normal_text_size"
                android:layout_marginBottom="@dimen/small_margin" />

            <LinearLayout
                android:id="@+id/servicios_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/agregar_servicio_btn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/agregar_servicio"
                android:layout_marginTop="@dimen/small_margin"
                android:layout_marginBottom="@dimen/medium_margin"
                style="@style/Widget.Material3.Button.OutlinedButton"
                app:cornerRadius="8dp" />

            <!-- Duraciones -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/mis_duraciones"
                android:textSize="@dimen/normal_text_size"
                android:layout_marginBottom="@dimen/small_margin" />

            <LinearLayout
                android:id="@+id/duraciones_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/agregar_duracion_btn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/agregar_duracion"
                android:layout_marginTop="@dimen/small_margin"
                android:layout_marginBottom="@dimen/medium_margin"
                style="@style/Widget.Material3.Button.OutlinedButton"
                app:cornerRadius="8dp" />

            <!-- Lugar de trabajo -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/lugar_trabajo_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/lugar_trabajo"
                app:helperText="@string/lugar_trabajo_hint"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_marginBottom="@dimen/medium_margin">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/lugar_trabajo_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textMultiLine"
                    android:maxLines="3"
                    android:gravity="top|start" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Información general -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/info_general_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/info_general"
                app:helperText="@string/info_general_hint"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_marginBottom="@dimen/medium_margin">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/info_general_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textMultiLine"
                    android:maxLines="5"
                    android:gravity="top|start" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- ADN del bot -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/adn_ia_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/adn_ia"
                app:helperText="@string/adn_ia_hint"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_marginBottom="@dimen/big_margin">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/adn_ia_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textMultiLine"
                    android:maxLines="8"
                    android:gravity="top|start" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/save_button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/save_settings"
                android:textSize="16sp"
                app:cornerRadius="8dp" />

            <!-- Zona de peligro -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/big_margin"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="#33D25140"
                app:strokeWidth="1.5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/activity_margin">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/danger_zone"
                        android:textColor="#D25140"
                        android:textSize="@dimen/normal_text_size"
                        android:textStyle="bold"
                        android:layout_marginBottom="@dimen/small_margin" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/delete_account_desc"
                        android:textSize="@dimen/smaller_text_size"
                        android:alpha="0.7"
                        android:layout_marginBottom="@dimen/medium_margin" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/delete_account_button"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/delete_account"
                        app:cornerRadius="8dp"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        app:strokeColor="#D25140"
                        android:textColor="#D25140" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:id="@+id/progress_indicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone"
        android:indeterminate="true" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
