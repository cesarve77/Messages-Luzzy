<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.goodwy.commons.views.MyAppBarLayout
        android:id="@+id/appbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/user_settings_title"
            app:titleTextAppearance="@style/AppTheme.ActionBar.TitleTextStyle"
            app:navigationIcon="@drawable/ic_arrow_left_vector" />
    </com.goodwy.commons.views.MyAppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/nested_scroll_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingHorizontal="@dimen/activity_padding_left_right"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Banner premium (solo no-premium) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/premium_banner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:visibility="gone"
                app:cardCornerRadius="@dimen/activity_margin"
                app:cardElevation="0dp"
                tools:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/activity_margin">

                    <com.goodwy.commons.views.MyTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/unlock_premium_features"
                        android:textStyle="bold"
                        android:layout_marginBottom="@dimen/small_margin" />

                    <com.goodwy.commons.views.MyTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/premium_features_description"
                        android:alpha="0.7"
                        android:layout_marginBottom="@dimen/medium_margin" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/upgrade_premium_button"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:tag="brand_fill"
                        android:text="@string/upgrade_to_premium"
                        app:cornerRadius="8dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ══════════ GENERAL ══════════ -->
            <TextView
                style="@style/SettingsSectionLabelStyle"
                android:layout_marginTop="12dp"
                android:tag="brand_text"
                android:text="@string/general_settings"
                tools:textColor="@color/primary" />

            <androidx.cardview.widget.CardView
                style="@style/SettingsSectionHolder"
                app:cardCornerRadius="@dimen/activity_margin"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Notificaciones silenciosas -->
                    <RelativeLayout
                        android:id="@+id/notificaciones_silenciosas_holder"
                        style="@style/SettingsHolderSwitchStyle">

                        <com.goodwy.commons.views.MyMaterialSwitch
                            android:id="@+id/notificaciones_silenciosas_switch"
                            style="@style/SettingsSwitchStyle"
                            android:text="@string/notificaciones_silenciosas"
                            app:switchPadding="@dimen/bigger_margin" />
                    </RelativeLayout>

                    <!-- Modo borrador global -->
                    <RelativeLayout
                        android:id="@+id/modo_borrador_global_holder"
                        style="@style/SettingsHolderSwitchStyle">

                        <com.goodwy.commons.views.MyMaterialSwitch
                            android:id="@+id/modo_borrador_global_switch"
                            style="@style/SettingsSwitchStyle"
                            android:text="@string/global_draft_mode"
                            app:switchPadding="@dimen/bigger_margin" />
                    </RelativeLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ══════════ PREMIUM ══════════ -->
            <TextView
                style="@style/SettingsSectionLabelStyle"
                android:tag="brand_text"
                android:text="@string/premium_settings"
                tools:textColor="@color/primary" />

            <androidx.cardview.widget.CardView
                style="@style/SettingsSectionHolder"
                app:cardCornerRadius="@dimen/activity_margin"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <RelativeLayout
                        android:id="@+id/auto_respuesta_holder"
                        style="@style/SettingsHolderSwitchStyle">

                        <com.goodwy.commons.views.MyMaterialSwitch
                            android:id="@+id/auto_respuesta_switch"
                            style="@style/SettingsSwitchStyle"
                            android:text="@string/auto_respuesta_activada"
                            app:switchPadding="@dimen/bigger_margin" />
                    </RelativeLayout>

                    <RelativeLayout
                        android:id="@+id/usar_emojis_holder"
                        style="@style/SettingsHolderSwitchStyle">

                        <com.goodwy.commons.views.MyMaterialSwitch
                            android:id="@+id/usar_emojis_switch"
                            style="@style/SettingsSwitchStyle"
                            android:text="@string/usar_emojis"
                            app:switchPadding="@dimen/bigger_margin" />
                    </RelativeLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ══════════ PERFIL PROFESIONAL ══════════ -->
            <TextView
                android:id="@+id/perfil_profesional_title"
                style="@style/SettingsSectionLabelStyle"
                android:tag="brand_text"
                android:text="@string/perfil_profesional"
                tools:textColor="@color/primary" />

            <androidx.cardview.widget.CardView
                android:id="@+id/perfil_card"
                style="@style/SettingsSectionHolder"
                app:cardCornerRadius="@dimen/activity_margin"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Nombre de usuario -->
                    <RelativeLayout
                        android:id="@+id/nombre_usuario_holder"
                        style="@style/SettingsHolderSwitchStyle">

                        <com.goodwy.commons.views.MyTextView
                            style="@style/SettingsTextLabelStyle"
                            android:layout_alignParentStart="true"
                            android:layout_centerVertical="true"
                            android:layout_toStartOf="@+id/nombre_usuario_input"
                            android:layout_marginEnd="@dimen/normal_margin"
                            android:text="@string/nombre_usuario" />

                        <EditText
                            android:id="@+id/nombre_usuario_input"
                            android:layout_width="160dp"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:layout_marginEnd="@dimen/settings_margin"
                            android:background="@null"
                            android:gravity="end"
                            android:hint="@string/nombre_usuario_helper"
                            android:inputType="textCapWords|textPersonName"
                            android:maxLines="1"
                            android:textSize="@dimen/bigger_text_size"
                            android:alpha="0.6" />
                    </RelativeLayout>

                    <!-- Servicios inline -->
                    <LinearLayout
                        android:id="@+id/servicios_section"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="@dimen/normal_margin"
                        android:paddingEnd="@dimen/normal_margin"
                        android:paddingTop="@dimen/smaller_margin"
                        android:paddingBottom="@dimen/smaller_margin">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minHeight="48dp">

                            <com.goodwy.commons.views.MyTextView
                                style="@style/SettingsTextLabelStyle"
                                android:layout_alignParentStart="true"
                                android:layout_centerVertical="true"
                                android:paddingStart="0dp"
                                android:paddingEnd="0dp"
                                android:text="@string/mis_servicios" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/agregar_servicio_btn"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:text="@string/agregar_servicio"
                                style="@style/Widget.Material3.Button.TextButton"
                                app:cornerRadius="8dp" />
                        </RelativeLayout>

                        <LinearLayout
                            android:id="@+id/servicios_container"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical" />
                    </LinearLayout>

                    <!-- Duraciones inline -->
                    <LinearLayout
                        android:id="@+id/duraciones_section"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="@dimen/normal_margin"
                        android:paddingEnd="@dimen/normal_margin"
                        android:paddingTop="@dimen/smaller_margin"
                        android:paddingBottom="@dimen/smaller_margin">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minHeight="48dp">

                            <com.goodwy.commons.views.MyTextView
                                style="@style/SettingsTextLabelStyle"
                                android:layout_alignParentStart="true"
                                android:layout_centerVertical="true"
                                android:paddingStart="0dp"
                                android:paddingEnd="0dp"
                                android:text="@string/mis_duraciones" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/agregar_duracion_btn"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:text="@string/agregar_duracion"
                                style="@style/Widget.Material3.Button.TextButton"
                                app:cornerRadius="8dp" />
                        </RelativeLayout>

                        <LinearLayout
                            android:id="@+id/duraciones_container"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical" />
                    </LinearLayout>

                    <!-- Lugar de trabajo -->
                    <LinearLayout
                        android:id="@+id/lugar_trabajo_holder"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="@dimen/normal_margin"
                        android:paddingEnd="@dimen/normal_margin"
                        android:paddingTop="@dimen/smaller_margin"
                        android:paddingBottom="@dimen/smaller_margin"
                        android:background="?attr/selectableItemBackground">

                        <com.goodwy.commons.views.MyTextView
                            style="@style/SettingsTextLabelStyle"
                            android:paddingStart="0dp"
                            android:paddingEnd="0dp"
                            android:text="@string/lugar_trabajo" />

                        <EditText
                            android:id="@+id/lugar_trabajo_input"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@null"
                            android:hint="@string/lugar_trabajo_hint"
                            android:inputType="textCapSentences|textMultiLine"
                            android:minLines="1"
                            android:maxLines="4"
                            android:textSize="@dimen/bigger_text_size"
                            android:alpha="0.6" />
                    </LinearLayout>

                    <!-- Info general -->
                    <LinearLayout
                        android:id="@+id/info_general_holder"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="@dimen/normal_margin"
                        android:paddingEnd="@dimen/normal_margin"
                        android:paddingTop="@dimen/smaller_margin"
                        android:paddingBottom="@dimen/smaller_margin"
                        android:background="?attr/selectableItemBackground">

                        <com.goodwy.commons.views.MyTextView
                            style="@style/SettingsTextLabelStyle"
                            android:paddingStart="0dp"
                            android:paddingEnd="0dp"
                            android:text="@string/info_general" />

                        <EditText
                            android:id="@+id/info_general_input"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@null"
                            android:hint="@string/info_general_hint"
                            android:inputType="textCapSentences|textMultiLine"
                            android:minLines="1"
                            android:maxLines="6"
                            android:textSize="@dimen/bigger_text_size"
                            android:alpha="0.6" />
                    </LinearLayout>

                    <!-- ADN IA -->
                    <LinearLayout
                        android:id="@+id/adn_ia_holder"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="@dimen/normal_margin"
                        android:paddingEnd="@dimen/normal_margin"
                        android:paddingTop="@dimen/smaller_margin"
                        android:paddingBottom="@dimen/smaller_margin"
                        android:background="?attr/selectableItemBackground">

                        <com.goodwy.commons.views.MyTextView
                            style="@style/SettingsTextLabelStyle"
                            android:paddingStart="0dp"
                            android:paddingEnd="0dp"
                            android:text="@string/adn_ia" />

                        <EditText
                            android:id="@+id/adn_ia_input"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@null"
                            android:hint="@string/adn_ia_hint"
                            android:inputType="textCapSentences|textMultiLine"
                            android:minLines="1"
                            android:maxLines="8"
                            android:textSize="@dimen/bigger_text_size"
                            android:alpha="0.6" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ══════════ INTEGRACIONES ══════════ -->
            <TextView
                style="@style/SettingsSectionLabelStyle"
                android:tag="brand_text"
                android:text="@string/integraciones"
                tools:textColor="@color/primary" />

            <androidx.cardview.widget.CardView
                style="@style/SettingsSectionHolder"
                app:cardCornerRadius="@dimen/activity_margin"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <RelativeLayout
                        android:id="@+id/calendar_holder"
                        style="@style/SettingsHolderSwitchStyle">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_alignParentStart="true"
                            android:layout_centerVertical="true"
                            android:layout_toStartOf="@+id/calendar_connect_button"
                            android:layout_marginEnd="@dimen/normal_margin">

                            <com.goodwy.commons.views.MyTextView
                                style="@style/SettingsTextLabelStyle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/google_calendar" />

                            <com.goodwy.commons.views.MyTextView
                                android:id="@+id/calendar_status_text"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/calendar_not_connected"
                                android:alpha="0.6"
                                android:textSize="@dimen/smaller_text_size" />
                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/calendar_connect_button"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:layout_marginEnd="@dimen/settings_margin"
                            android:text="@string/calendar_connect"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            app:cornerRadius="8dp" />
                    </RelativeLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ══════════ ACCESO WEB ══════════ -->
            <TextView
                style="@style/SettingsSectionLabelStyle"
                android:tag="brand_text"
                android:text="@string/acceso_web"
                tools:textColor="@color/primary" />

            <androidx.cardview.widget.CardView
                style="@style/SettingsSectionHolder"
                app:cardCornerRadius="@dimen/activity_margin"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Email -->
                    <LinearLayout
                        android:id="@+id/email_holder"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="@dimen/normal_margin"
                        android:paddingEnd="@dimen/normal_margin"
                        android:paddingTop="@dimen/smaller_margin"
                        android:paddingBottom="@dimen/smaller_margin">

                        <com.goodwy.commons.views.MyTextView
                            style="@style/SettingsTextLabelStyle"
                            android:paddingStart="0dp"
                            android:paddingEnd="0dp"
                            android:text="@string/email_label" />

                        <EditText
                            android:id="@+id/email_input"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@null"
                            android:hint="@string/email_hint"
                            android:inputType="textEmailAddress"
                            android:maxLines="1"
                            android:textSize="@dimen/bigger_text_size" />
                    </LinearLayout>

                    <!-- Contraseña -->
                    <LinearLayout
                        android:id="@+id/password_holder"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="@dimen/normal_margin"
                        android:paddingEnd="@dimen/normal_margin"
                        android:paddingTop="@dimen/smaller_margin"
                        android:paddingBottom="@dimen/smaller_margin">

                        <com.goodwy.commons.views.MyTextView
                            style="@style/SettingsTextLabelStyle"
                            android:paddingStart="0dp"
                            android:paddingEnd="0dp"
                            android:text="@string/password_label" />

                        <EditText
                            android:id="@+id/password_input"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@null"
                            android:hint="@string/password_hint"
                            android:inputType="textPassword"
                            android:maxLines="1"
                            android:textSize="@dimen/bigger_text_size" />
                    </LinearLayout>

                    <!-- Leyenda -->
                    <com.goodwy.commons.views.MyTextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingStart="@dimen/normal_margin"
                        android:paddingEnd="@dimen/normal_margin"
                        android:paddingTop="@dimen/smaller_margin"
                        android:paddingBottom="@dimen/smaller_margin"
                        android:text="@string/acceso_web_leyenda"
                        android:textSize="@dimen/smaller_text_size"
                        android:alpha="0.7" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Guardar -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/save_button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="@dimen/medium_margin"
                android:tag="brand_fill"
                android:text="@string/save_settings"
                android:textSize="16sp"
                app:cornerRadius="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/logout_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/small_margin"
                android:tag="brand_text"
                android:text="@string/logout_google"
                style="@style/Widget.Material3.Button.OutlinedButton"
                app:cornerRadius="8dp" />

            <!-- Zona de peligro -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/big_margin"
                android:layout_marginBottom="@dimen/big_margin"
                app:cardCornerRadius="@dimen/activity_margin"
                app:cardElevation="0dp"
                app:strokeColor="#33D25140"
                app:strokeWidth="1.5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/activity_margin">

                    <com.goodwy.commons.views.MyTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/danger_zone"
                        android:textColor="#D25140"
                        android:textStyle="bold"
                        android:layout_marginBottom="@dimen/small_margin" />

                    <com.goodwy.commons.views.MyTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/delete_account_desc"
                        android:alpha="0.7"
                        android:layout_marginBottom="@dimen/medium_margin" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/delete_account_button"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/delete_account"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        app:cornerRadius="8dp"
                        app:strokeColor="#D25140"
                        android:textColor="#D25140" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:id="@+id/progress_indicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone"
        android:indeterminate="true" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
