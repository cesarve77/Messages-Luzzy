    <string name="prominent_disclosure_title">Avis de confidentialité</string>
    <string name="prominent_disclosure_message">Luzzy collecte et transmet votre numéro de téléphone et les contacts de votre appareil pour permettre l\'envoi et la réception de messages SMS entre utilisateurs. Ces informations sont envoyées à nos serveurs uniquement à cette fin et ne sont pas partagées avec des tiers.</string>
